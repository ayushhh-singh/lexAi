# Server
NODE_ENV=development
PORT=3001
CLIENT_URL=http://localhost:5173

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# AI
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Razorpay — use test keys for local dev (https://dashboard.razorpay.com/app/keys)
# Get test keys from Razorpay Dashboard > Settings > API Keys > Generate Test Key
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Indian Kanoon API (optional — falls back to knowledge base search without it)
# Apply at: https://api.indiankanoon.org/
INDIAN_KANOON_API_KEY=

# Feature flags — set these for production-like local testing
ENFORCE_CREDITS=false
BETA_MODE=false
SHOW_PRICING=true

# Skill IDs (env-specific — dev and prod have different IDs)
SKILL_ID_INDIAN_LEGAL_DRAFTER=
SKILL_ID_COURT_FORMATTER=
